# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# Map static resources from the /public folder to the /assets URL path
# GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)

GET     /products           controllers.ProductController.getAll()
GET     /products/:id       controllers.ProductController.getById(id: Int)
POST    /products           controllers.ProductController.create()
PUT     /products/:id       controllers.ProductController.update(id: Int)
DELETE  /products/:id       controllers.ProductController.delete(id: Int)

GET     /categories                controllers.CategoryController.getAll()
GET     /categories/:id            controllers.CategoryController.getById(id: Long)
GET     /categories/:id/products   controllers.CategoryController.getProductsByCategory(id: Long)
POST    /categories                controllers.CategoryController.create()
PUT     /categories/:id            controllers.CategoryController.update(id: Long)
DELETE  /categories/:id            controllers.CategoryController.delete(id: Long)

GET     /cart                      controllers.CartController.getCart()
POST    /cart/items                controllers.CartController.addItem()
PUT     /cart/items/:productId     controllers.CartController.updateItem(productId: Int)
DELETE  /cart/items/:productId     controllers.CartController.removeItem(productId: Int)
DELETE  /cart                      controllers.CartController.clearCart()